{
  "name": "@sidhujag/sysweb3-keyring",
  "version": "1.0.606",
  "description": "Keyring Manager for UTXO and Web3 Wallets",
  "main": "cjs/index.js",
  "types": "types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syscoin/sysweb3.git"
  },
  "author": "Pali Wallet",
  "license": "MIT",
  "private": false,
  "engines": {
    "yarn": ">= 1.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist/",
    "build": "tsc && tsc -p tsconfig.json",
    "prerelease": "yarn build",
    "copy": "node ../../scripts/package/copy",
    "release:npm": "yarn publish ./dist --access=public --no-git-tag-version",
    "release:preflight": "yarn pack ./dist --dry-run",
    "publishCode": "yarn prebuild && yarn prerelease && yarn copy && yarn release:npm",
    "type-check": "tsc --pretty --noEmit",
    "localTest": "yarn prebuild && yarn build && yarn copy",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@ledgerhq/hw-app-eth": "^6.47.1",
    "@ledgerhq/hw-transport-webhid": "^6.30.5",
    "@ledgerhq/logs": "^6.10.1",
    "@metamask/eth-sig-util": "^8.2.0",
    "@sidhujag/sysweb3-core": "^1.0.28",
    "@sidhujag/sysweb3-network": "^1.0.109",
    "@sidhujag/sysweb3-utils": "^1.1.277",
    "@trezor/connect-web": "^9.7.1",
    "@trezor/connect-webextension": "^9.7.1",
    "@trezor/utxo-lib": "^1.0.12",
    "bip32": "^5.0.1",
    "bip32-path": "^0.4.2",
    "bitcoin-ops": "^1.4.1",
    "bitcoinjs-lib": "^7.0.1",
    "crypto-js": "^4.1.1",
    "ethers": "^6.17.0"
  },
  "peerDependencies": {
    "syscoinjs-lib": "^1.0.271"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.1.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.8.10",
    "dotenv": "^16.0.3",
    "rimraf": "^6.0.1",
    "syscoinjs-lib": "^1.0.271",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "wif": "^5.0.0"
  },
  "resolutions": {
    "axios": "^1.18.1",
    "jws": "^4.0.1"
  }
}
