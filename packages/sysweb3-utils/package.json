{
  "name": "@sidhujag/sysweb3-utils",
  "version": "1.1.277",
  "description": "A helper for multi-chain accounts.",
  "main": "cjs/index.js",
  "types": "types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syscoin/sysweb3.git"
  },
  "author": "Pali Wallet",
  "license": "MIT",
  "private": false,
  "engines": {
    "yarn": ">= 1.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist/",
    "build": "tsc && tsc -p tsconfig.json",
    "prerelease": "yarn build",
    "copy": "node ../../scripts/package/copy",
    "release:npm": "yarn publish ./dist --access=public --no-git-tag-version",
    "release:preflight": "yarn pack ./dist --dry-run",
    "publishCode": "yarn prebuild && yarn prerelease && yarn copy && yarn release:npm",
    "test": "jest",
    "type-check": "tsc --pretty --noEmit",
    "localTest": "yarn prebuild && yarn build && yarn build && yarn copy"
  },
  "dependencies": {
    "@sidhujag/sysweb3-network": "^1.0.109",
    "bech32": "^2.0.0",
    "crypto-js": "^4.1.1",
    "ethers": "^6.17.0"
  },
  "peerDependencies": {
    "syscoinjs-lib": "^1.0.271"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.1.1",
    "@types/node": "^17.0.23",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "syscoinjs-lib": "^1.0.271"
  }
}
